# ==========================================================================
# Credenciais e configuracoes da plataforma (valores demo do projeto).
# Centralizadas aqui: o docker-compose e os scripts leem daqui, sem
# credenciais chumbadas no codigo.
# ==========================================================================

# --- PostgreSQL ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
# POSTGRES_DB = banco de metadados do Airflow
POSTGRES_DB=airflow
# POSTGRES_DATA_DB = banco do projeto (ABT e fontes)
POSTGRES_DATA_DB=data
# POSTGRES_HOST = nome do servico no compose; em execucao local use localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Infra ---
AIRFLOW_DB=airflow
METABASE_DB=metabase
AIRFLOW_UID=1000
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# --- Chaves de seguranca do Airflow ---
AIRFLOW_SECRET_KEY=tcc_fia_labdata_engenharia_dados
AIRFLOW_FERNET_KEY=7777777777777777777777777777777777777777777=

# --- Usuario admin do Airflow ---
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_ROLE=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# --- Tamanho dos pools da DAG (paralelismo por etapa) ---
POOL_INGESTAO_SIZE=2
POOL_SANITIZATION_SIZE=2
POOL_AGGREGATION_SIZE=2

# --- Jupyter ---
JUPYTER_TOKEN=analytics

# --- Servico de predicao (credit-api) ---
MODEL_PATH=/app/Model/artifacts/lightgbm_abt.pkl
MODEL_LOAD_RETRY_SECONDS=5
CREDIT_APPROVE_MAX_SCORE=0.50
CREDIT_MANUAL_REVIEW_MAX_SCORE=0.60
CREDIT_POLICY_VERSION=demo-v1
